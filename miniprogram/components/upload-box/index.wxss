.upload-box {
  width: 100%;
  min-height: 360rpx;
  background: #F5EDE4;
  border: 2rpx solid #E8DDD0;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.upload-placeholder {
  width: 100%;
  height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx dashed #C4875A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #C4875A;
  line-height: 1;
}

.upload-hint {
  font-size: 28rpx;
  color: #8B7355;
}

.upload-preview {
  width: 100%;
  height: 360rpx;
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 32rpx;
  line-height: 1;
}