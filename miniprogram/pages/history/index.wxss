.page {
  min-height: 100vh;
  background: #FFFAF5;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background: #FFFAF5;
}

.nav-bar {
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: #FFFAF5;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
}

.nav-action {
  font-size: 28rpx;
  color: #C4875A;
}

.content-scroll {
  flex: 1;
  padding: 32rpx 40rpx;
  padding-bottom: 200rpx;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.history-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E8DDD0;
  position: relative;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #F5EDE4;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-label {
  font-size: 24rpx;
  color: #8B7355;
}

.item-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  background: #F5EDE4;
}

.item-time {
  font-size: 24rpx;
  color: #8B7355;
  margin-top: auto;
}

.item-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #5C4033;
  font-weight: 500;
}

.empty-hint {
  font-size: 28rpx;
  color: #8B7355;
}

/* 加载更多 */
.loading, .no-more {
  padding: 32rpx;
  text-align: center;
}

.loading-text, .no-more-text {
  font-size: 28rpx;
  color: #8B7355;
}