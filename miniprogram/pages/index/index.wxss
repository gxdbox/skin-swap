.page {
  min-height: 100vh;
  background: #FFFAF5;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background: #FFFAF5;
}

.nav-bar {
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFAF5;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
}

.content-scroll {
  flex: 1;
  padding: 32rpx 40rpx;
  padding-bottom: 200rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #5C4033;
  margin-bottom: 24rpx;
  display: block;
}

.section-note {
  font-size: 24rpx;
  color: #8B7355;
  margin-top: 16rpx;
  display: block;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-link {
  font-size: 28rpx;
  color: #C4875A;
}

/* 布料网格 */
.fabric-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.fabric-grid.hidden {
  display: none;
}

.fabric-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.fabric-item.selected {
  border-color: #C4875A;
}

.fabric-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fabric-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #C4875A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
}

.fabric-name {
  font-size: 24rpx;
  color: #8B7355;
  text-align: center;
  margin-top: 8rpx;
  display: block;
}

/* 自定义布料 */
.custom-fabric {
  margin-bottom: 24rpx;
}

.custom-fabric .fabric-item {
  width: 160rpx;
  padding-bottom: 160rpx;
  margin: 0 auto;
}

.fabric-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  z-index: 1;
}

/* 合成结果 */
.result-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.result-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.result-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.result-hint {
  color: #FFFFFF;
  font-size: 28rpx;
  text-align: center;
  display: block;
}

/* 空状态 */
.empty-state {
  width: 100%;
  height: 240rpx;
  background: #F5EDE4;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7355;
}

/* 操作按钮 */
.action-area {
  padding: 32rpx 0;
  padding-bottom: 200rpx;
}

.btn-fuse {
  width: 100%;
  height: 100rpx;
  background: #C4875A;
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-fuse.disabled {
  opacity: 0.6;
}

.btn-fuse:active {
  opacity: 0.8;
}