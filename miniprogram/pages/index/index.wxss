.page {
  min-height: 100vh;
  background: #FFFAF5;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background: #FFFAF5;
}

.nav-bar {
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFAF5;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
}

.content-scroll {
  flex: 1;
  padding: 32rpx 40rpx;
  padding-bottom: 200rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #5C4033;
  margin-bottom: 24rpx;
  display: block;
}

.section-note {
  font-size: 24rpx;
  color: #8B7355;
  margin-top: 16rpx;
  display: block;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-link {
  font-size: 28rpx;
  color: #C4875A;
}

/* 布料网格 */
.fabric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.fabric-grid.hidden {
  display: none;
}

.fabric-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 24rpx;
  overflow: hidden;
  background: #F5EDE4;
  border: 2rpx solid #E8DDD0;
  transition: all 0.2s ease;
}

.fabric-item.upload-item {
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.fabric-item.upload-item:active {
  opacity: 0.8;
}

.fabric-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.upload-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx dashed #C4875A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #C4875A;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #8B7355;
}

.fabric-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  z-index: 1;
  line-height: 1;
}

/* 合成结果 */
.result-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.result-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.result-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.result-hint {
  color: #FFFFFF;
  font-size: 28rpx;
  text-align: center;
  display: block;
}

/* 空状态 */
.empty-state {
  width: 100%;
  height: 240rpx;
  background: #F5EDE4;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8B7355;
}

/* 操作按钮 */
.action-area {
  padding: 32rpx 0;
  padding-bottom: 200rpx;
}

.btn-fuse {
  width: 100%;
  height: 100rpx;
  background: #C4875A;
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-fuse.disabled {
  opacity: 0.6;
}

.btn-fuse:active {
  opacity: 0.8;
}