.page {
  min-height: 100vh;
  background: #FFFAF5;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background: #FFFAF5;
}

.nav-bar {
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFAF5;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
}

.content-container {
  flex: 1;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.section {
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #5C4033;
  margin-bottom: 12rpx;
  display: block;
}

.section-note {
  font-size: 20rpx;
  color: #8B7355;
  margin-top: 8rpx;
  display: block;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-link {
  font-size: 28rpx;
  color: #C4875A;
}

/* 布料网格 */
.fabric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.fabric-grid.hidden {
  display: none;
}

.fabric-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 24rpx;
  overflow: hidden;
  background: #F5EDE4;
  border: 2rpx solid #E8DDD0;
  transition: all 0.2s ease;
}

.fabric-item.upload-item {
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.fabric-item.upload-item:active {
  opacity: 0.8;
}

.fabric-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.upload-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx dashed #C4875A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #C4875A;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #8B7355;
}

.fabric-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  z-index: 1;
  line-height: 1;
}

/* 合成效果预览区 */
.result-section {
  margin-bottom: 0;
}

/* 合成结果 */
.result-container {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.result-container-small {
  height: 100rpx;
}

.result-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.result-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.result-hint {
  color: #FFFFFF;
  font-size: 28rpx;
  text-align: center;
  display: block;
}

/* 空状态 */
.empty-state {
  width: 100%;
  height: 160rpx;
  background: #F5EDE4;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.empty-state-small {
  height: 100rpx;
  flex-direction: row;
}

.empty-icon {
  font-size: 48rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #8B7355;
}

.empty-text-small {
  font-size: 26rpx;
  color: #8B7355;
}

/* 悬浮合成按钮 */
.floating-action {
  position: fixed;
  bottom: 180rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 99;
}

.btn-fuse {
  width: 100%;
  height: 80rpx;
  background: #C4875A;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(196, 135, 90, 0.4);
}

.btn-fuse.disabled {
  opacity: 0.6;
}

.btn-fuse:active {
  opacity: 0.8;
}

/* 操作按钮（已废弃） */
.action-area {
  display: none;
}

/* AI 合成中 Loading 弹窗 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.loading-overlay.show {
  opacity: 1;
  visibility: visible;
}

.loading-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.loading-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.loading-icon {
  font-size: 64rpx;
  animation: sparkle 1.5s ease infinite;
}

@keyframes sparkle {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.8; }
}

.loading-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C4033;
  text-align: center;
}

/* 进度条 */
.progress-container {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #F5EDE4;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4875A, #D49A6A);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #C4875A;
  min-width: 80rpx;
  text-align: right;
}

/* 预览图 */
.preview-section {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.preview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.preview-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  border: 3rpx solid #F5EDE4;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.preview-label {
  font-size: 22rpx;
  color: #8B7355;
  text-align: center;
}

.preview-arrow {
  font-size: 40rpx;
  color: #C4875A;
  margin-top: 40rpx;
  animation: pulse 1s ease infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}

/* 时间估算 */
.time-estimate {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFFAF5;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid #F5EDE4;
}

.time-icon {
  font-size: 32rpx;
}

.time-text {
  font-size: 26rpx;
  color: #5C4033;
  font-weight: 500;
}

/* 趣味提示 */
.loading-tip {
  width: 100%;
  background: linear-gradient(135deg, #FFF8F0, #FFF0E0);
  padding: 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #F5EDE4;
}

.loading-tip-text {
  font-size: 26rpx;
  color: #8B7355;
  line-height: 1.6;
  text-align: center;
  display: block;
}