<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 标题栏 -->
  <view class="nav-bar">
    <text class="nav-title">图片融合</text>
  </view>

  <!-- 主内容 -->
  <scroll-view scroll-y class="content-scroll">
    <!-- 主体上传区 -->
    <view class="section">
      <text class="section-title">主体图片（沙发）</text>
      <upload-box
        image="{{sofaImage}}"
        hint="点击上传沙发图片"
        bind:upload="onUploadSofa"
        bind:delete="onDeleteSofa"
      />
      <text class="section-note">仅支持上传一张图片</text>
    </view>

    <!-- 布料选择区 -->
    <view class="section">
      <text class="section-title">选择布料</text>
      <text class="section-note">最多可上传5张布料</text>
      
      <!-- 布料网格 -->
      <view class="fabric-grid">
        <!-- 已上传的布料 -->
        <view
          wx:for="{{customFabrics}}"
          wx:key="id"
          class="fabric-item"
        >
          <image class="fabric-image" src="{{item.image}}" mode="aspectFill" />
          <view class="fabric-delete" data-id="{{item.id}}" bindtap="onDeleteFabric">×</view>
        </view>
        
        <!-- 上传按钮（如果未达到5张） -->
        <view
          wx:if="{{customFabrics.length < 5}}"
          class="fabric-item upload-item"
          bindtap="onUploadFabric"
        >
          <view class="upload-placeholder">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传布料</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 合成效果区 -->
    <view class="section">
      <text class="section-title">合成效果</text>

      <!-- 合成结果 -->
      <view wx:if="{{result}}" class="result-container" bindtap="onViewResult">
        <image class="result-image" src="{{result.image}}" mode="aspectFill" />
        <view class="result-overlay">
          <text class="result-hint">点击查看详情</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:else class="empty-state">
        <text class="empty-icon">🎨</text>
        <text class="empty-text">上传图片后开始合成</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-area">
      <button
        class="btn-fuse {{isProcessing ? 'disabled' : ''}}"
        bindtap="onStartFuse"
        disabled="{{isProcessing}}"
      >
        {{isProcessing ? '合成中...' : '开始合成'}}
      </button>
    </view>
  </scroll-view>

  <!-- 底部导航 -->
  <tab-bar current="0" />
</view>