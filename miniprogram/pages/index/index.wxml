<view class="page">
  <!-- 状态栏 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 标题栏 -->
  <view class="nav-bar">
    <text class="nav-title">图片融合</text>
  </view>

  <!-- 主内容 -->
  <view class="content-container">
    <!-- 主体上传区 -->
    <view class="section">
      <text class="section-title">主体图片（沙发）</text>
      <upload-box
        image="{{sofaImage}}"
        hint="点击上传沙发图片"
        bind:upload="onUploadSofa"
        bind:delete="onDeleteSofa"
      />
      <text class="section-note">仅支持上传一张图片</text>
    </view>

    <!-- 布料选择区 -->
    <view class="section">
      <text class="section-title">选择布料</text>
      <text class="section-note">最多可上传5张布料</text>
      
      <!-- 布料网格 -->
      <view class="fabric-grid">
        <!-- 已上传的布料 -->
        <view
          wx:for="{{customFabrics}}"
          wx:key="id"
          class="fabric-item"
        >
          <image class="fabric-image" src="{{item.image}}" mode="aspectFill" />
          <view class="fabric-delete" data-id="{{item.id}}" bindtap="onDeleteFabric">×</view>
        </view>
        
        <!-- 上传按钮（如果未达到5张） -->
        <view
          wx:if="{{customFabrics.length < 5}}"
          class="fabric-item upload-item"
          bindtap="onUploadFabric"
        >
          <view class="upload-placeholder">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传布料</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 合成效果区 -->
    <view class="section">
      <text class="section-title">合成效果</text>

      <!-- 合成结果 -->
      <view wx:if="{{result}}" class="result-container" bindtap="onViewResult">
        <image class="result-image" src="{{result.image}}" mode="aspectFill" />
        <view class="result-overlay">
          <text class="result-hint">点击查看详情</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:else class="empty-state">
        <text class="empty-icon">🎨</text>
        <text class="empty-text">上传图片后开始合成</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-area">
      <button
        class="btn-fuse {{isProcessing ? 'disabled' : ''}}"
        bindtap="onStartFuse"
        disabled="{{isProcessing}}"
      >
        {{isProcessing ? '合成中...' : '开始合成'}}
      </button>
    </view>
  </view>

  <!-- AI 合成中 Loading 弹窗 -->
  <view class="loading-overlay {{isProcessing ? 'show' : ''}}" wx:if="{{isProcessing}}">
    <view class="loading-content">
      <!-- 标题 -->
      <view class="loading-title">
        <text class="loading-icon">✨</text>
        <text class="loading-title-text">AI 正在为您的沙发换肤</text>
      </view>

      <!-- 进度条 -->
      <view class="progress-container">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{loadingProgress}}%"></view>
        </view>
        <text class="progress-text">{{loadingProgress}}%</text>
      </view>

      <!-- 预览图 -->
      <view class="preview-section">
        <view class="preview-item">
          <image class="preview-image" src="{{sofaImage}}" mode="aspectFill" />
          <text class="preview-label">沙发原图</text>
        </view>
        <view class="preview-arrow">→</view>
        <view class="preview-item">
          <image class="preview-image" src="{{customFabrics[0]?.image}}" mode="aspectFill" />
          <text class="preview-label">布料参考</text>
        </view>
      </view>

      <!-- 时间估算 -->
      <view class="time-estimate">
        <text class="time-icon">⏱️</text>
        <text class="time-text">{{estimatedTimeText}}</text>
      </view>

      <!-- 趣味提示 -->
      <view class="loading-tip">
        <text class="loading-tip-text">{{loadingTip}}</text>
      </view>
    </view>
  </view>
</view>