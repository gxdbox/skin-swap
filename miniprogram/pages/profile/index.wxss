.page {
  min-height: 100vh;
  background: #F5EDE4;
  display: flex;
  flex-direction: column;
}

.status-bar {
  background: #FFFAF5;
}

.nav-bar {
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: #FFFFFF;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5C4033;
}

.nav-setting {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.setting-icon {
  font-size: 40rpx;
}

.content-scroll {
  flex: 1;
  padding: 32rpx 40rpx;
  padding-bottom: 200rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx;
  background: #FFFAF5;
  border-radius: 32rpx;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-placeholder {
  font-size: 64rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #5C4033;
}

.user-id {
  font-size: 24rpx;
  color: #8B7355;
}

.arrow-icon {
  font-size: 40rpx;
  color: #CCCCCC;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 32rpx;
  padding: 32rpx;
  background: #FFFAF5;
  border-radius: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #5C4033;
}

.stat-label {
  font-size: 24rpx;
  color: #8B7355;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #E0E0E0;
}

/* 菜单卡片 */
.menu-card {
  margin-top: 32rpx;
  background: #FFFAF5;
  border-radius: 32rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 112rpx;
}

.menu-item.has-border {
  border-bottom: 2rpx solid #F0F0F0;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-name {
  font-size: 28rpx;
  color: #5C4033;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}